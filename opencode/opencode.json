{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen3-coder:30b-48k-od",
  "autoupdate": false,
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen3-coder:30b-48k-od": {
          "name": "Qwen3-Coder 30B 48K OD-safe (Ollama local)",
          "limit": {
            "context": 49152,
            "output": 12000
          }
        }
      }
    }
  },
  "permission": {
    "*": "allow",
    "bash": "allow",
    "edit": "allow",
    "read": "allow"
  }
}
